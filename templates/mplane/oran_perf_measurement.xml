<config xmlns="urn:ietf:params:xml:ns:netconf:base:1.0">
<performance-measurement-objects xmlns="urn:o-ran:performance-management:1.0">
    <enable-SFTP-upload>false</enable-SFTP-upload>
    <enable-random-file-upload>false</enable-random-file-upload>
    <rx-window-measurement-interval>60</rx-window-measurement-interval>
    <notification-interval>60</notification-interval>
    <remote-SFTP-uploads>
      <remote-SFTP-upload-path>sftp://root@192.168.1.20:22/home/root/222.cvs</remote-SFTP-upload-path>
      <password>
        <password>root</password>
      </password>
    </remote-SFTP-uploads>
    <rx-window-measurement-objects>
        <measurement-object>RX_ON_TIME</measurement-object>
        <active>true</active>
        <object-unit>RU</object-unit>
        <report-info>COUNT</report-info>
    </rx-window-measurement-objects>
    <rx-window-measurement-objects>
        <measurement-object>RX_EARLY</measurement-object>
        <active>true</active>
        <object-unit>RU</object-unit>
        <report-info>COUNT</report-info>
    </rx-window-measurement-objects>
    <rx-window-measurement-objects>
        <measurement-object>RX_LATE</measurement-object>
        <active>true</active>
        <object-unit>RU</object-unit>
        <report-info>COUNT</report-info>
    </rx-window-measurement-objects>
        <rx-window-measurement-objects>
        <measurement-object>RX_ON_TIME_C</measurement-object>
        <active>true</active>
        <object-unit>RU</object-unit>
        <report-info>COUNT</report-info>
    </rx-window-measurement-objects>
    <rx-window-measurement-objects>
        <measurement-object>RX_EARLY_C</measurement-object>
        <active>true</active>
        <object-unit>RU</object-unit>
        <report-info>COUNT</report-info>
    </rx-window-measurement-objects>
    <rx-window-measurement-objects>
        <measurement-object>RX_LATE_C</measurement-object>
        <active>true</active>
        <object-unit>RU</object-unit>
        <report-info>COUNT</report-info>
    </rx-window-measurement-objects>
    <rx-window-measurement-objects>
        <measurement-object>RX_CORRUPT</measurement-object>
        <active>true</active>
        <object-unit>RU</object-unit>
        <report-info>COUNT</report-info>
    </rx-window-measurement-objects>
    <rx-window-measurement-objects>
        <measurement-object>RX_DUPL</measurement-object>
        <active>true</active>
        <object-unit>RU</object-unit>
        <report-info>COUNT</report-info>
    </rx-window-measurement-objects>
    <rx-window-measurement-objects>
        <measurement-object>RX_TOTAL</measurement-object>
        <active>true</active>
        <object-unit>RU</object-unit>
        <report-info>COUNT</report-info>
    </rx-window-measurement-objects>
    <transceiver-measurement-objects>
        <measurement-object>RX_POWER</measurement-object>
        <active>true</active>
        <report-info>MAXIMUM</report-info>
        <report-info>MINIMUM</report-info>
        <report-info>FIRST</report-info>
        <report-info>LATEST</report-info>
        <report-info>FREQUENCY_TABLE</report-info>
        <object-unit>PORT_NUMBER</object-unit>
        <function>LOG_10</function>
        <bin-count>5</bin-count>
        <lower-bound>-14.409</lower-bound>
        <upper-bound>0.499</upper-bound>
    </transceiver-measurement-objects> 
    <transceiver-measurement-objects>
        <measurement-object>TX_POWER</measurement-object>
        <active>true</active>
        <report-info>MAXIMUM</report-info>
        <report-info>MINIMUM</report-info>
        <report-info>FIRST</report-info>
        <object-unit>PORT_NUMBER</object-unit>
        <function>LOG_10</function>
        <bin-count>5</bin-count>
    </transceiver-measurement-objects>
    <transceiver-measurement-objects>
        <measurement-object>TX_BIAS_COUNT</measurement-object>
        <active>true</active>
        <report-info>MAXIMUM</report-info>
        <report-info>MINIMUM</report-info>
        <report-info>FIRST</report-info>
        <report-info>LATEST</report-info>
        <object-unit>PORT_NUMBER</object-unit>
        <function>RAW</function>
        <bin-count>5</bin-count>
    </transceiver-measurement-objects>       
</performance-measurement-objects>
</config>