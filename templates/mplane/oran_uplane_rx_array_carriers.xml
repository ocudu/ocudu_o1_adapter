    <downlink-radio-frame-offset>0</downlink-radio-frame-offset>
    <downlink-sfn-offset>0</downlink-sfn-offset>
    <gain-correction>0.0000</gain-correction>
    <n-ta-offset>0</n-ta-offset>
  </rx-array-carriers>
  <rx-array-carriers>
    <name>Rx-Array-Carrier-02</name>
    <absolute-frequency-center>{{ config.ul_arfcn }}</absolute-frequency-center>
